; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Synth Fleet"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
ThemeManager="*res://scripts/autoload/theme_manager.gd"
LoopMixer="*res://scripts/autoload/loop_mixer.gd"
ShipRegistry="*res://scripts/autoload/ship_registry.gd"
SfxPlayer="*res://scripts/autoload/sfx_player.gd"
KeyBindingManager="*res://scripts/autoload/key_binding_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"

